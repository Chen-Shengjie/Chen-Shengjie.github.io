---
---
<div class="row">
  <div id="{{ entry.key }}" class="col-sm-12">
    
    <div class="title" style="font-weight: 600; font-size: 1.1rem; color: #2c3e50;">{{ entry.title }}</div>
    
    <div class="author" style="margin-top: 0.2rem; color: #4a4a4a;">
      {% assign author_array_size = entry.author_array | size %}
      {%- for author in entry.author_array -%}
        {%- assign author_last_name = author.last | regex_replace: '[*∗†‡§¶‖&^]', '' -%}
        {% assign author_is_self = false %}
        {% if site.scholar.last_name contains author_last_name %}
          {% if site.scholar.first_name contains author.first %}
            {% assign author_is_self = true %}
          {% endif %}
        {%- endif -%}

        {%- if forloop.length > 1 -%}
          {% if forloop.first == false -%}
            {%- if forloop.length > 2 %}, {% elsif forloop.length == 2 %} and {% endif %}
          {%- endif %}
          {%- if forloop.last and author_array_size > 2 %}and {% endif -%}
        {% endif %}
        
        {%- if author_is_self -%}
          <strong>{{ author.first }} {{ author.last }}</strong>
        {%- else -%}
          {{ author.first }} {{ author.last }}
        {%- endif -%}
      {% endfor %}
    </div>

    {% assign proceedings = 'inproceedings,incollection' | split: ',' %}
    {% assign thesis = 'thesis,mastersthesis,phdthesis' | split: ',' %}
    {% if entry.type == 'article' %}
      {% capture entrytype %}<em>{{ entry.journal }}</em>{% endcapture %}
    {% elsif proceedings contains entry.type %}
      {% capture entrytype %}<em>In {{ entry.booktitle }}</em>{% endcapture %}
    {% elsif thesis contains entry.type %}
      {% capture entrytype %}<em>{{ entry.school }}</em>{% endcapture %}
    {% else %}
      {% capture entrytype %}{% endcapture %}
    {% endif %}
    {% assign entryyear = '' %}
    {% if entry.year %}
      {% capture entryyear %}{{ entry.year }}{% endcapture %}
    {% endif %}
    
    {% capture periodical %}{{ entrytype }}{% if entrytype != "" and entryyear != "" %}, {% endif %}{{ entryyear }}{% endcapture %}
    <div class="periodical" style="font-style: italic; margin-top: 0.2rem;">
      {{ periodical | strip }}
    </div>

    <div class="links" style="margin-top: 0.5rem;">
      {% if entry.abstract %}
        <a class="abstract btn btn-sm z-depth-0" role="button">Details</a>
      {% endif %}
      {% if entry.pdf %}
        <a href="{{ entry.pdf }}" class="btn btn-sm z-depth-0" role="button" target="_blank">Draft</a>
      {% endif %}
      {% if entry.code %}
        <a href="{{ entry.code }}" class="btn btn-sm z-depth-0" role="button" target="_blank">Code</a>
      {% endif %}
      {% if entry.slides %}
        <a href="{{ entry.slides }}" class="btn btn-sm z-depth-0" role="button" target="_blank">Slides</a>
      {% endif %}
      {% if entry.website %}
        <a href="{{ entry.website }}" class="btn btn-sm z-depth-0" role="button" target="_blank">Website</a>
      {% endif %}
    </div>

    {% if entry.abstract %}
      <div class="abstract hidden" style="margin-top: 1rem; padding: 1rem; background-color: #f8f9fa; border-left: 3px solid #2c3e50;">
        <p style="margin-bottom: 0;">{{ entry.abstract }}</p>
      </div>
    {% endif %}

  </div>
</div>
